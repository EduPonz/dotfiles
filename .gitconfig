[user]
	email = eduardoponz@eprosima.com
	name = eduponz
    signingkey = 49D026A07DE7858343F965CBA3271B51629DF2A4
[alias]
    lg = "!f() { \
            lines=$1; \
            if [ -z $lines ]; then lines=10; fi; \
            git log -n $lines --color --pretty=format:'%Cred%h %Cgreen(%cr) %C(bold blue)%an%Creset - %s %C(yellow)%d%Creset' --abbrev-commit; \
        }; f"
[credential]
	helper = store
[http "https://gitlab.intranet.eprosima.com"]
    sslVerify = false
[commit]
    gpgsign = true
[core]
	editor = vim
